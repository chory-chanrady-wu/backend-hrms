          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"jane.smith\",\n  \"email\": \"jane@example.com\",\n  \"passwordHash\": \"password123\",\n  \"fullName\": \"Jane Smith\",\n  \"roleId\": 4\n}"
        },
        "url": {
          "raw": "http://localhost:7777/api/v1/auth/register",
